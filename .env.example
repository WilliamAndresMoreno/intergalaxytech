# ─── .env.example ─────────────────────────────────────────────────
# Copia este archivo como .env y ajusta los valores.
# NUNCA versionar .env con credenciales reales.
# En Azure, estos valores se configuran en App Service > Configuration
# o se referencian desde Azure Key Vault.

# SQLite (local / desarrollo)
CONNECTION_STRING=Data Source=/app/data/intergalaxytech.db

# Azure SQL Database (producción) — descomentar y rellenar:
# CONNECTION_STRING=Server=tcp:<servidor>.database.windows.net,1433;Initial Catalog=IntergalaxyTechDB;Persist Security Info=False;User ID=<usuario>;Password=<password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

ASPNETCORE_ENVIRONMENT=Production
